# ──────────────────────────────────────────────────────────────
#  Unified Balance Dashboard — окружение
#  Скопируй этот файл в .env.local и заполни свои ключи
# ──────────────────────────────────────────────────────────────

# Режим сети: "testnet" | "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# EVM кошелёк (приватный ключ с 0x)
# Получить тестовые USDC: https://faucet.circle.com (выбери Base Sepolia)
EVM_PRIVATE_KEY=0xYOUR_EVM_PRIVATE_KEY

# Solana кошелёк (base58 приватный ключ)
# Получить тестовые SOL: https://faucet.solana.com
SOLANA_PRIVATE_KEY=YOUR_SOLANA_PRIVATE_KEY_BASE58

# Адрес получателя для операции Spend (куда отправить после консолидации)
# По умолчанию = тот же адрес EVM кошелька
EVM_RECIPIENT_ADDRESS=0xYOUR_RECIPIENT_ADDRESS

# ── Demo Mode ──────────────────────────────────────────────────
# Если EVM_PRIVATE_KEY не задан — дашборд работает в demo-режиме
# с реалистичными моковыми данными. Это поведение по умолчанию.
