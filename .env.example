# ──────────────────────────────────────────────────────────────
#  Unified Balance Dashboard — окружение
#  Скопируй этот файл в .env.local и заполни свои значения
# ──────────────────────────────────────────────────────────────

# Адрес EVM-кошелька для чтения USDC-балансов с тестнетов.
# Это ПУБЛИЧНЫЙ адрес (0x...), НЕ приватный ключ — безопасно хранить.
# Без этой переменной дашборд работает в demo-режиме с mock-данными.
# Пример: WALLET_ADDRESS=0xAbCd1234...
WALLET_ADDRESS=

# Режим сети: "testnet" | "mainnet"
NEXT_PUBLIC_NETWORK=testnet

# ── Demo Mode ──────────────────────────────────────────────────
# Если WALLET_ADDRESS не задан — дашборд работает в demo-режиме
# с реалистичными mock-данными. Это поведение по умолчанию.
